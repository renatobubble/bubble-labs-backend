# ═══════════════════════════════════════════════════════════════════
# CONFIGURAÇÕES DO BACKEND BUBBLE LABS
# ═══════════════════════════════════════════════════════════════════

# Porta do servidor
PORT=3000

# Ambiente
NODE_ENV=development

# NOTION CONFIGURATION
# Obtenha seu token em: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxx

# GOOGLE DRIVE CONFIGURATION
# Obtenha seu token OAuth em: https://console.cloud.google.com
GOOGLE_DRIVE_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxx
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxx

# CORS SETTINGS
CORS_ORIGIN=*

# DATABASE (opcional, para armazenar histórico)
DATABASE_URL=sqlite:./bubble_labs.db

# LOGGING
LOG_LEVEL=info
